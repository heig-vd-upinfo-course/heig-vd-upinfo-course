---
// JavaScript comes here.
---

<div id="feedback">
	<p>
		Qu'avez-vous pensé de ce contenu ? Votre retour nous aide à nous améliorer,
		merci ! Vous pouvez nous laisser des commentaires plus détaillés dans la
		page {` `}
		<a href="/heig-vd-upinfo-course/10-autre/01-contribuer-a-ce-site">
			Contribuer à ce site
		</a>.
	</p>
</div>

<div class="container">
	<button
		type="button"
		aria-pressed="false"
		data-umami-event="feedback"
		data-umami-event-value="positive"
	>
		🙂
	</button>

	<button
		type="button"
		aria-pressed="false"
		data-umami-event="feedback"
		data-umami-event-value="neutral"
	>
		😐
	</button>

	<button
		type="button"
		aria-pressed="false"
		data-umami-event="feedback"
		data-umami-event-value="negative"
	>
		🙁
	</button>
</div>

<script>
	const feedbackContainer = document.querySelector(".container");
	const feedbackButtons = feedbackContainer?.querySelectorAll("button") ?? [];

	feedbackButtons.forEach((button) => {
		button.addEventListener("click", () => {
			feedbackButtons.forEach((candidate) => {
				candidate.classList.remove("is-selected");
				candidate.setAttribute("aria-pressed", "false");
			});

			button.classList.add("is-selected");
			button.setAttribute("aria-pressed", "true");
		});
	});
</script>

<style>
	.container {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.container button {
		all: unset;
		box-sizing: border-box;
		width: 60px;
		height: 60px;
		border-radius: 50%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 1.75rem;
		line-height: 1;
		cursor: pointer;
		transition:
			transform 0.2s ease,
			opacity 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	.container button:hover {
		transform: scale(1.1);
		opacity: 0.9;
	}

	.container button:active {
		transform: scale(0.92);
	}

	.container button:focus-visible {
		outline: 2px solid currentColor;
		outline-offset: 4px;
	}

	.container button.is-selected {
		background-color: color-mix(in srgb, currentColor 18%, transparent);
		box-shadow: 0 0 0 3px color-mix(in srgb, currentColor 30%, transparent);
		transform: scale(1.08);
		opacity: 1;
	}
</style>
